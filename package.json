{
  "name": "@applied-leverage/engram",
  "version": "0.1.0",
  "description": "Unified memory and context engine plugin for OpenClaw — absorbs Lossless Claw, Gigabrain, and OpenStinger into a single plugin",
  "type": "module",
  "main": "index.ts",
  "bin": {
    "engram": "./src/cli/engram-cli.ts"
  },
  "license": "MIT",
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "context-management",
    "memory",
    "llm",
    "summarization",
    "conversation-memory",
    "dag"
  ],
  "files": [
    "index.ts",
    "src/**/*.ts",
    "openclaw.plugin.json",
    "docs/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "changeset": "changeset",
    "release:verify": "npm test && npm pack --dry-run",
    "test": "vitest run --dir test",
    "version-packages": "changeset version"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "*",
    "@mariozechner/pi-ai": "*",
    "@sinclair/typebox": "0.34.48",
    "falkordb": "^6.6.2",
    "sqlite-vec": "^0.1.7-alpha.2"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "publishConfig": {
    "access": "public"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  }
}
